{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "excludeFiles": [
                    "vendor/google/apiclient-services/src/Google/Service/[A-C]*/**",
                    "vendor/google/apiclient-services/src/Google/Service/[A-C]*.php",
                    "vendor/google/apiclient-services/src/Google/Service/[E-Z]*/**",
                    "vendor/google/apiclient-services/src/Google/Service/[E-Z]*.php",
                    "node_modules/**",
                    "tests/**",
                    "vendor/**/tests/**"
                ]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*\\.xlsx|.*\\.csv|.*\\.png|.*\\.jpg)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "database",
        "CACHE_DRIVER": "database",
        "VIEW_COMPILED_PATH": "/tmp"
    }
}
